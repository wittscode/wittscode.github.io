---
layout: base.njk
title: Home
---

<section class="post-list">
  <h1>Posts</h1>

  {% if collections.posts.length %}
    <ul>
      {% for post in collections.posts %}
        <li class="post-item">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <time datetime="{{ post.date }}">{{ post.date | readableDate }}</time>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No posts yet.</p>
  {% endif %}
</section>
